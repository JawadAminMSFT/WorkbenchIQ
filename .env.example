# Azure Content Understanding Configuration
# Use Azure AD authentication (recommended for direct Cognitive Services access)
AZURE_CONTENT_UNDERSTANDING_USE_AZURE_AD=true
AZURE_CONTENT_UNDERSTANDING_ENDPOINT=https://your-resource.cognitiveservices.azure.com
# API key only needed if not using Azure AD (or if using APIM)
# AZURE_CONTENT_UNDERSTANDING_API_KEY=your-api-key

# Optional: override default analyzer and API version
AZURE_CONTENT_UNDERSTANDING_ANALYZER_ID=prebuilt-documentSearch
AZURE_CONTENT_UNDERSTANDING_API_VERSION=2025-11-01

# Azure OpenAI Configuration
AZURE_OPENAI_ENDPOINT=https://your-openai.openai.azure.com
AZURE_OPENAI_API_KEY=your-openai-key
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4-1
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_MODEL_NAME=gpt-4.1

# Chat-specific model for Ask IQ feature (uses lighter model for cost efficiency)
# If not set, falls back to main deployment above
AZURE_OPENAI_CHAT_DEPLOYMENT_NAME=gpt-4-1-mini
AZURE_OPENAI_CHAT_MODEL_NAME=gpt-4.1-mini

# Application Storage Configuration
# STORAGE_BACKEND options: "local" (default) or "azure_blob"
STORAGE_BACKEND=local

# Local storage configuration (used when STORAGE_BACKEND=local)
UW_APP_STORAGE_ROOT=data


# Azure Blob Storage configuration (used when STORAGE_BACKEND=azure_blob)
#
# Authentication precedence (default mode): DAC → connection string → account key.
# Override with AZURE_STORAGE_AUTH_MODE to force a specific method.
#
# AZURE_STORAGE_AUTH_MODE options:
#   "default"           - try DefaultAzureCredential first, then fall back (recommended)
#   "connection_string" - use connection string only
#   "key"               - use account name + key only
AZURE_STORAGE_AUTH_MODE=default

# Account name is required for DAC and key auth
AZURE_STORAGE_ACCOUNT_NAME=mystorageaccount

# Account key — only needed when not using managed identity / DAC
# AZURE_STORAGE_ACCOUNT_KEY=abc123...

# Connection string — alternative to account name + key
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...

AZURE_STORAGE_CONTAINER_NAME=workbenchiq-data

# Container auto-creation (default: false).
# Set to true only in dev/migration scenarios where the identity has create perms.
# In production, pre-create the container and assign "Storage Blob Data Contributor".
AZURE_STORAGE_ALLOW_CREATE_CONTAINER=false

# Default timeout and retry settings that can be overridden
# AZURE_STORAGE_TIMEOUT_SECONDS=30
# AZURE_STORAGE_RETRY_TOTAL=3
